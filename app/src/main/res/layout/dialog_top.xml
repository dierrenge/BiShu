<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="350dp"
    android:layout_height="180dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/translucent"
    android:gravity="center"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="320dp"
        android:layout_height="150dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/catalogBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="25dp"
                    android:background="@drawable/btn_bg1"
                    android:textColor="@color/blackGray"
                    android:textSize="16dp"
                    android:text="目录"/>
                <Button
                    android:id="@+id/readBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="25dp"
                    android:background="@drawable/btn_bg1"
                    android:textColor="@color/blackGray"
                    android:textSize="16dp"
                    android:text="朗读"/>
                <Button
                    android:id="@+id/readSetBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="25dp"
                    android:background="@drawable/btn_bg1"
                    android:textColor="@color/blackGray"
                    android:textSize="16dp"
                    android:text="引擎"/>

                <Button
                    android:visibility="gone"
                    android:id="@+id/powerSetBtn"
                    android:layout_width="75dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="25dp"
                    android:background="@drawable/btn_bg1"
                    android:textColor="@color/blackGray"
                    android:textSize="16dp"
                    android:text="省电策略"/>
                <Button
                    android:id="@+id/replaceBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginLeft="25dp"
                    android:background="@drawable/btn_bg1"
                    android:textColor="@color/blackGray"
                    android:textSize="16dp"
                    android:text="替换"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/readDialogB"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="25dp"
                    android:textColor="@color/gray3"
                    android:textSize="13.5dp"
                    android:text="• 双击屏幕亦可朗读/停止"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="25dp"
                    android:textColor="@color/gray3"
                    android:textSize="13.5dp"
                    android:text="• 推荐下载讯飞语记，切换引擎设置更多语音"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/replaceDialogB"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:gravity="bottom"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/replaceOld"
                    android:layout_width="70dp"
                    android:layout_height="32dp"
                    android:layout_marginLeft="24dp"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:background="@drawable/edit_text_bg3"
                    android:gravity="center"
                    android:textSize="17dp"
                    android:inputType="text"
                    android:textColor="@color/gray2"
                    android:textColorHint="@color/gray2"
                    android:textCursorDrawable="@drawable/edit_text_cursor"
                    android:maxLines="1"/>
                <ImageButton
                    android:id="@+id/replaceBtnBtn"
                    android:scaleX="-1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="15dp"
                    android:scaleType="fitCenter"
                    android:background="@drawable/replace_btn"
                    android:gravity="center" />
                <EditText
                    android:id="@+id/replaceNew"
                    android:layout_width="70dp"
                    android:layout_height="32dp"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:background="@drawable/edit_text_bg3"
                    android:gravity="center"
                    android:textSize="17dp"
                    android:inputType="text"
                    android:textColor="@color/gray2"
                    android:textColorHint="@color/gray2"
                    android:textCursorDrawable="@drawable/edit_text_cursor"
                    android:maxLines="1"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
